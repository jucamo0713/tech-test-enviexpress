NODE_ENV=development
PORT=3000
APP_NAME=nestjs-backend
API_PREFIX=api
LOG_LEVEL=log
DEFAULT_TIMEOUT_MS=30000
MONGO_ENABLED=true
MONGO_URI=mongodb://localhost:27017/enviexpress
REDIS_URL=redis://localhost:6379
GRPC_AUTH_URL=0.0.0.0:50051
GRPC_USERS_URL=0.0.0.0:50052
GRPC_CLIENTS_URL=0.0.0.0:50053
GRPC_PACKAGES_URL=0.0.0.0:50054
GRPC_PACKAGE_STATUS_URL=0.0.0.0:50055
GRPC_AUDIT_URL=0.0.0.0:50056
JWT_ACCESS_SECRET=change-me-super-secret
JWT_ACCESS_EXPIRES_IN=15m
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
SWAGGER_TITLE='Enviexpress API'
SWAGGER_DESCRIPTION='Enviexpress backend API documentation'
SWAGGER_VERSION=1.0.0
